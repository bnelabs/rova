/* Rova — modern dark theme (inspired by Claude Code / Catppuccin Mocha) */

Screen {
    background: #11111b;
    color: #cdd6f4;
}

#rova-header {
    dock: top;
    height: 3;
    padding: 0 1;
    background: #181825;
    color: #cdd6f4;
    text-style: bold;
    border-bottom: solid #313244;
}

#main-content {
    height: 1fr;
}

#chat-view {
    width: 3fr;
    border-right: solid #313244;
    padding: 0 1;
    background: #11111b;
}

#sidebar {
    width: 1fr;
    min-width: 26;
    max-width: 34;
    padding: 1;
    background: #181825;
    border-left: solid #313244;
}

#sidebar-state,
#sidebar-workspace,
#sidebar-skills {
    margin-bottom: 1;
    padding: 0 1;
}

#command-palette {
    dock: bottom;
    height: auto;
    max-height: 14;
    margin: 0 1 1 1;
    padding: 1 2;
    background: #1e1e2e;
    color: #cdd6f4;
    border: solid #cba6f7;
    border-bottom: none;
    display: none;
    overflow-y: auto;
}

#command-palette.-visible {
    display: block;
}

#chat-input {
    dock: bottom;
    height: auto;
    min-height: 3;
    max-height: 10;
    margin: 0;
    border-top: solid #313244;
    background: #181825;
    color: #cdd6f4;
}

#chat-input:focus {
    border-top: solid #cba6f7;
}

/* TextArea inner text widget */
TextArea {
    background: #181825;
    color: #cdd6f4;
    border: none;
    padding: 0 1;
}

TextArea:focus {
    border: none;
}

TextArea > .text-area--cursor-line {
    background: #1e1e2e;
}

TextArea > .text-area--selection {
    background: #45475a;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: #1e1e2e;
    color: #6c7086;
    padding: 0 1;
}

#help-container {
    padding: 1 2;
    background: #11111b;
    color: #cdd6f4;
}

#help-text {
    padding: 1;
    background: #181825;
    border: solid #313244;
}

#help-close {
    margin-top: 1;
    width: 20;
}

/* RichLog styling */
RichLog {
    background: #11111b;
    color: #cdd6f4;
}

RichLog:focus {
    border: none;
}

/* Button styling */
Button {
    background: #313244;
    color: #cdd6f4;
    border: solid #45475a;
}

Button:hover {
    background: #45475a;
    color: #f5c2e7;
}

/* Input styling */
Input {
    background: #181825;
    color: #cdd6f4;
    border: none;
}

Input:focus {
    border: none;
}

/* Scrollbar styling */
Scrollbar {
    background: #11111b;
    color: #585b70;
}

Scrollbar:hover {
    background: #313244;
    color: #cba6f7;
}
